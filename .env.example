# HubSpot private app token. Scopes: crm.objects.contacts.read,
# crm.objects.contacts.write, crm.schemas.contacts.read, crm.schemas.contacts.write
HUBSPOT_ACCESS_TOKEN=pat-xxx-your-hubspot-private-app-token

# Shared secret you set on the Wati webhook (?secret=... or x-webhook-secret header)
WATI_WEBHOOK_SECRET=replace-with-a-long-random-secret


# Local dev port. On Hostinger this is provided automatically — leave it unset there.
PORT=3001

# Wati API access (profile → API Docs). Used to list Wati contacts in the dashboard.
WATI_API_ENDPOINT=
WATI_API_TOKEN=
